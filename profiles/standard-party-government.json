  "page": {
    "paper": "A4",
    "top_margin_cm": 3.7,
    "bottom_margin_cm": 3.5,
    "left_margin_cm": 2.8,
    "right_margin_cm": 2.6
  },
  "layout": {
    "lines_per_page": 22,
    "chars_per_line": 28,
    "line_spacing_pt": 28,
    "first_line_indent_chars": 2,
    "space_before_pt": 0,
    "space_after_pt": 0
  },
  "signature": {
    "style": "no-seal-single-issuer",
    "blank_lines_before": 1,
    "right_empty_chars": 2,
    "note": "For no-seal single-issuer drafts, place issuer one blank line below body or attachment notes, aligned on the right with two-character right space; place date on the next line. Sealed documents may use different stamp-aware placement."
  },
  "fonts": {
