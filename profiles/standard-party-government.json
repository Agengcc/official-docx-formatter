{
  "profile_id": "standard-party-government",
  "display_name": "党政机关公文标准配置",
  "description": "参考 GB/T 9704-2012《党政机关公文格式》和《党政机关公文处理工作条例》的通用正式公文格式配置。",
  "inherits": null,
  "standard_basis": [
    "GB/T 9704-2012",
    "党政机关公文处理工作条例",
    "GB/T 33476.2-2016"
