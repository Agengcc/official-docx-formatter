      "fallbacks": ["方正小标宋简体", "小标宋体", "华文中宋", "Songti SC", "宋体", "SimSun"],
      "size_pt": 22,
      "bold": false
    },
    "body": {
      "fallbacks": ["仿宋_GB2312", "仿宋", "STFangsong", "FangSong"],
      "size_pt": 16,
      "bold": false
    },
    "level1": {
      "fallbacks": ["黑体", "SimHei", "Heiti SC"],
      "size_pt": 16,
      "bold": true
    },
    "level2": {
      "fallbacks": ["楷体_GB2312", "楷体", "Kaiti SC", "KaiTi"],
      "size_pt": 16,
      "bold": false
    },
    "page_number": {
